# ── GHDL Compilation Artifacts ───────────────────────────────────────────────
# Object files and library catalogs produced by `ghdl -a`
# Rebuilt automatically by run_autotest.sh / run_sim.sh
ghdl_work/
*.o
*.cf
# GHDL elaboration link objects (e~<entity>.o at repo root)
e~*

# ── GHDL Elaborated Binaries (root-level executables) ────────────────────────
# Produced by `ghdl -e`; rebuilt on every simulation run
/tb_autotest
/tb_video_dump
/test08

# ── GHDL Simulation Waveform Dumps ───────────────────────────────────────────
# VCD/GHW files can be hundreds of MB — regenerated by ghdl --wave / --vcd
*.vcd
*.ghw

# ── Compiled Program Outputs ─────────────────────────────────────────────────
# ELF and .mem hex files generated by `make compile PROG=...`
# Fully reproducible from source — never commit compiled binaries
mem/
*.elf
*.map
*.d

# ── Simulation Working Files ─────────────────────────────────────────────────
# Per-test result dirs, intermediate .mem/.out/.setup/.irq/.res, and the
# 4MB VRAM write log from Space Invaders simulation — all regeneratable
# Leading slash anchors to repo root so vhd/sim/ (VHDL source stubs) is NOT matched
/sim/

# ── Local Build Cache ─────────────────────────────────────────────────────────
# Symlink or directory created by directory.mk pointing to /tmp/<user>/.CEPcache
.CEPcache

# ── Vivado Synthesis / Implementation Outputs ────────────────────────────────
# Bitstreams, checkpoints, reports, logs — all generated by Vivado
*.jou
*.log
*.str
vivado*/
*.runs/
*.cache/
*.hw/
*.ip_user_files/
*.xpr
*.bit
*.dcp
*.ltx
*.mmi
*.rpt
*.xsa

# ── Vivado XSim Simulation Outputs ───────────────────────────────────────────
# Generated by xsim; waveform databases and build artifacts
xsim.dir/
*.wdb
*.pb

# ── Autotest Generated Results ───────────────────────────────────────────────
# Regenerated by make autotest / gen_res.sh — never commit
/autotest.res
/tag.res
/log

# ── Temporary / Intermediate Config Files ────────────────────────────────────
# Pre-computed video memory dump, not part of source
config/tmp_video.mem

# ── Rendered Simulation Frames ───────────────────────────────────────────────
# Per-frame PNGs are regenerated by `python3 scripts/render_frames.py`
# frames/invaders.gif is intentionally committed (used in README)
frames/*.png

# ── Compiled Binary Utility ──────────────────────────────────────────────────
# img_to_mem is a compiled host binary; keep shell scripts and .awk only
bin/img_to_mem

# ── Python Cache ─────────────────────────────────────────────────────────────
# Generated by Python 3 (scripts/render_frames.py and any future scripts)
__pycache__/
*.pyc
*.pyo

# ── OS-Specific Files ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# ── IDE / Editor Files ───────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.orig
TODO.md
